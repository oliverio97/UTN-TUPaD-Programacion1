# paso de objetos mutables (en este caso una lista). Esto es una MODIFICACION de listas, modificamos la referencia a la lista original


def modificar_lista(lista):
    print(f"Dentro de la funcion antes de modificiar: {lista}")
    lista.append(4)
    print(f"Dentro de la funcion despues de modificar: {lista}")


mi_lista = [1, 2, 3]
modificar_lista(mi_lista)
print(f"Fuera de la funcion: {mi_lista}")
# como podemos ver, la lista se modifica en la funcion, y al salir de esta tambien sigue modificada

# Ahora seguimos con objeto mutable, pero en este caso vemos REASIGNACION de lista


def reasignar_lista(lista):
    print(f"Dentro de la funcion antes de reasignar: {lista}")
    lista = [4, 4, 4]
    print(f"Dentro de la funcion despues de reasignar: {lista}")


mi_lista = [1, 2, 3]
reasignar_lista(mi_lista)
print(f"Fuera de la funcion: {mi_lista}")
# como vemos, la reasignacion no afecta al objeto original.
# al reasignar un objeto mutable, el objeto con la reasignacion
#  genera una referencia nueva


# Ahora vamos a ver que pasa cuando tenemos una MATRIZ, vamos a MODIFICARLA


def agregar_elemento(matriz):
    matriz[0].append(99)  # este caso es una moficicacion
    matriz.append([4, 5, 6])  # este caso tambien


matriz = [[1, 2], [3, 4]]
agregar_elemento(matriz)
print(f"Matriz final: {matriz}")
# como podemos ver, por fuera de la funcion la matriz se modifica tambien.

# Ahora vamos a REEMPLAZAR UNA SUBLISTA dentro de una matriz


def reemplazar_sublista(matriz):
    matriz[0] = [0, 0, 0]  # reasignacion interna, reemplaza la referencia


matriz = [[1, 2], [3, 4]]
reemplazar_sublista(matriz)
print(f"Matriz final: {matriz}")
# como vemos, al acceder a un valor de la matriz, y luego lo reasignamos,
# si afecta a la matriz original

# ahora vemos una comparacion entre MODIFICACION de un objeto y la REASIGNACION


def operar_lista(lst):
    lst.append(10)  # modifica el objeto original
    lst = [0, 0, 0]  # reasigna la variable local
    print(f"Lista dentro de la funcion operar: {lst}")


lista = [1, 2, 3]
operar_lista(lista)
print(f"Lista final: {lista}")


# Por ultimo, vemos la CLONACION SUPERFICIAL Y CLONACION PROFUNDA

# usamos el metodo copy y el metodo deepcopy del modulo copy
import copy


def modificar_listas(original, copia_superficial, copia_profunda):
    original[0][0] = "X"
    copia_superficial[0][1] = "Y"
    copia_profunda[0][2] = "Z"


data = [[1, 2, 3], [4, 5, 6]]
copia_superficial = copy.copy(data)
copia_Prof = copy.deepcopy(data)

modificar_listas(data, copia_superficial, copia_Prof)

print(f"Original: {data}")
print(f"Copia superficial: {copia_superficial}")
print(f"Copia profunda: {copia_Prof}")

# la copia superficial solo hace una copia del arreglo entero,
# no de las referencias a sus valores internos por lo cual si cambiamos los valores se cambian en ambos, porque
# sigue haciendo referencia a la lista original

# en cambio en deepcopy, estamos haciendo una copia totalmente distinta de la lista original,
# que copia tanto la lista en general como las listas internas.
